{
  "rewrites": [
    {
      "source": "/map",
      "destination": "/map.html"
    },
    {
      "source": "/map/",
      "destination": "/map.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}